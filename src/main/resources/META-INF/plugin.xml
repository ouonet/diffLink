<idea-plugin>
    <id>com.neo.difflink</id>
    <name>DiffLink</name>
    <vendor>neo</vendor>

    <description><![CDATA[
        <p>DiffLink opens file comparisons directly from inline <code>@DiffLink</code> markers.</p>
        <p>Add <code>@DiffLink:path/to/file</code> or <code>@DiffLink:source, destination</code> in a comment or plain-text line, then click the gutter icon to launch IntelliJ IDEA's built-in diff viewer.</p>
        <p>DiffLink is designed for refactoring and migration workflows where you frequently compare old and new implementations.</p>

        <h3>Highlights</h3>
        <ul>
            <li>One-click diff from editor gutter markers</li>
            <li>Single-target and explicit two-file compare formats</li>
            <li>Git history compare via <code>git://ref:path</code> syntax — compare any branch, tag, or commit SHA</li>
            <li>Works across common text-based files (Java, Kotlin, Python, JavaScript, Markdown, XML, shell, config)</li>
            <li>Clear error markers for missing or invalid paths</li>
            <li>Local-only behavior: no source upload, no remote diff processing</li>
        </ul>

        <h3>Marker examples</h3>
        <pre><code>@DiffLink:src/main/java/legacy/OldImplementation.java
@DiffLink:/Users/me/project/v1/File.kt, /Users/me/project/v2/File.kt
@DiffLink: git://HEAD~1:src/main/kotlin/Foo.kt
@DiffLink: git://main:src/Foo.kt, git://dev:src/Foo.kt</code></pre>

        <h3>Screenshots</h3>
        <p><img src="https://raw.githubusercontent.com/ouonet/diffLink/1.0.0/src/main/resources/01-marker-in-editor.png" alt="Marker in editor with gutter icon" width="600"/></p>
        <p><img src="https://raw.githubusercontent.com/ouonet/diffLink/1.0.0/src/main/resources/02-diff-viewer-result.png" alt="Diff viewer result" width="600"/></p>
        <p><img src="https://raw.githubusercontent.com/ouonet/diffLink/1.0.0/src/main/resources/03-invalid-path-feedback.png" alt="Invalid path feedback" width="600"/></p>

        <p><b>Compatibility:</b> IntelliJ IDEA Community and Ultimate, build 232+ (2023.2.1 and later).</p>
        <p><b>Privacy:</b> local-only processing. DiffLink does not upload source code or diff content.</p>
    ]]></description>

    <version>1.1.1</version>
    <idea-version since-build="232" />
    <change-notes><![CDATA[
        <p>See CHANGELOG.md for detailed release notes.</p>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!--
          lineMarkerProvider is a LanguageExtension: the platform requires a concrete,
          non-empty language ID per registration. "ANY" and "" are both rejected at
          install time. The list below covers all languages supported by JetBrains IDEs.
          The implementation itself is fully language-agnostic (raw leaf-text scan),
          so no per-language code changes are ever needed.
        -->
        <!-- JVM -->
        <codeInsight.lineMarkerProvider language="JAVA"             implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="kotlin"           implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="Groovy"           implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="Scala"            implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <!-- Scripting / dynamic -->
        <codeInsight.lineMarkerProvider language="Python"           implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="Ruby"             implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="PHP"              implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="Lua"              implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <!-- Systems -->
        <codeInsight.lineMarkerProvider language="C"                implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="C++"              implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="go"               implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="Rust"             implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="ObjectiveC"       implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="Swift"            implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <!-- Web -->
        <codeInsight.lineMarkerProvider language="JavaScript"       implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="TypeScript"       implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="HTML"             implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="CSS"              implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="SCSS"             implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="Vue"              implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <!-- Data / config -->
        <codeInsight.lineMarkerProvider language="XML"              implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="JSON"             implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="YAML"             implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="TOML"             implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="Properties"       implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="Ini"              implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="Dockerfile"       implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <!-- Text / docs -->
        <codeInsight.lineMarkerProvider language="TEXT"             implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="Markdown"         implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="Shell Script"     implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="SQL"              implementationClass="com.neo.difflink.markers.CompareMarkerProvider"/>
        <notificationGroup id="DiffLink" displayType="BALLOON" />
    </extensions>

    <actions>
        <action id="DiffLink.ShowDiff"
                class="com.neo.difflink.actions.CompareActionHandler"
                text="Show Comparison">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift C" />
        </action>
    </actions>
</idea-plugin>
