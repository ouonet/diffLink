<idea-plugin>
    <id>com.lianggong.comparenavigator</id>
    <name>Compare Navigator</name>
    <vendor email="liang.gong@gmail.com" url="https://github.com/lianggong/compare-navigator">
        Liang Gong
    </vendor>

    <description><![CDATA[
        Navigate and compare files during refactoring using #COMPARE markers. Mark any text file with #COMPARE:/path/to/file or #COMPARE:/src, /dst markers, and click the gutter icon to instantly compare files using IntelliJ's diff viewer. Works with Java, Python, Kotlin, JavaScript, Markdown, configuration files, and more.
    ]]></description>

    <version>0.0.1</version>
    <idea-version since-build="232" />

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <codeInsight.lineMarkerProvider implementationClass="com.lianggong.comparenavigator.markers.CompareMarkerProvider" />
        <notificationGroup id="Compare Navigator" displayType="BALLOON" />
    </extensions>

    <actions>
        <action id="CompareNavigator.ShowDiff"
                class="com.lianggong.comparenavigator.actions.CompareActionHandler"
                text="Show Comparison">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift C" />
        </action>
    </actions>
</idea-plugin>
