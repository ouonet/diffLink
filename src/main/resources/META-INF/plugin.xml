<idea-plugin>
    <id>com.lianggong.difflink</id>
    <name>DiffLink</name>
    <vendor email="liang.gong@gmail.com" url="https://github.com/lianggong/difflink">
        Liang Gong
    </vendor>

    <description><![CDATA[
        Navigate and compare files during refactoring using #DiffLink markers. Mark any text file with #DiffLink:/path/to/file or #DiffLink:/src, /dst markers, and click the gutter icon to instantly compare files using IntelliJ's diff viewer. Works with Java, Python, Kotlin, JavaScript, Markdown, configuration files, and more.
    ]]></description>

    <version>0.0.1</version>
    <idea-version since-build="232" />

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <codeInsight.lineMarkerProvider implementationClass="com.lianggong.difflink.markers.CompareMarkerProvider" />
        <notificationGroup id="DiffLink" displayType="BALLOON" />
    </extensions>

    <actions>
        <action id="DiffLink.ShowDiff"
                class="com.lianggong.difflink.actions.CompareActionHandler"
                text="Show Comparison">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift C" />
        </action>
    </actions>
</idea-plugin>
